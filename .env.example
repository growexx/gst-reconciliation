# ── Copy to .env and fill in ──

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=gst_reco

# Company list shown on the login screen (comma-separated).
# These are logical company ids (replaces the old SAP "Company DB" / schema).
COMPANIES=Nandan Terry

# Bootstrap login used ONLY when the users collection is empty.
# Once you run `npm run seed:user`, real users in Mongo take over.
BOOTSTRAP_USER=admin
BOOTSTRAP_PASS=admin123

# ── SAP /zapi_tables API (on-demand fetch at reconcile time) ──
# Base URL (production PS4). Set the host HERE only — never per-endpoint.
SAP_API_BASE_URL=https://vhntxps4ap01.sap.nandanterry.com/zapi_tables
SAP_API_CLIENT=500
# SAP service-account login (single shared account in an SAP custom table). Backend-only —
# NOT the app's user login. The token is fetched/cached/refreshed server-side (2h expiry).
# Use a strong password and a secret manager in production, not these defaults.
SAP_API_USER=
SAP_API_PASSWORD=
# How many months on EACH side of the reconcile month to pull SAP data for (posting
# date). ±2 catches bills posted a month or two off their invoice date. Higher = a bit
# more accuracy for late-posted bills, slightly slower. Fetch is fast, so 2–3 is fine.
SAP_FETCH_MONTHS=2
# Pull SAP live on each 2B upload. false = reconcile against data already loaded by
# the offline ETL (scripts/loadSapData.js) instead.
SAP_FETCH_ON_RECONCILE=true
# Internal SAP cert isn't publicly trusted → relaxed TLS for SAP calls only.
# Set false once the CA is installed on the app server.
SAP_API_INSECURE_TLS=true
# Fetch tuning — many small parallel calls (see server/modules/sap/sapClient.js).
# Raise CONCURRENCY on a stable LAN for speed; small CHUNK/WINDOW_DAYS keep each
# response small so a flaky link doesn't stall.
SAP_API_CONCURRENCY=8
SAP_API_CHUNK=25
SAP_API_WINDOW_DAYS=3
SAP_API_VENDOR_CHUNK=50
SAP_API_TIMEOUT_MS=60000
SAP_API_RETRIES=5
# SAP_API_BSEG_ALL=true   # fetch BSEG for every AP doc (exact ETL parity) vs KR/KG only
# GL account the import IGST posts to (for IMPG / Bill-of-Entry matching).
SAP_IMPG_IGST_GL=0000170025
